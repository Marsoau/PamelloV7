<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PamelloV7.Server.Consolonia.Screens"
             xmlns:controls="clr-namespace:PamelloV7.Server.Consolonia.Controls"
             xmlns:messages="clr-namespace:PamelloV7.Framework.Logging.Messages;assembly=PamelloV7.Framework"
             x:Class="PamelloV7.Server.Consolonia.Screens.LogScreen">
    <Grid RowDefinitions="*,Auto" Background="#080808">
        <ScrollViewer
            x:Name="MessageList"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            IsScrollInertiaEnabled="False"
            Grid.Row="0"
            >
            
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel /> 
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="messages:RefreshableLogMessage">
                        <controls:RefreshableMessageControl HorizontalAlignment="Stretch" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <Grid Grid.Row="1" Background="#161616">
            <Button x:Name="CopyButton" HorizontalAlignment="Right" Content="Copy All" Click="CopyButton_OnClick"/>
        </Grid>
    </Grid>
</UserControl>