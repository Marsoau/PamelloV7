<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:console="https://github.com/jinek/consolonia"
             x:Class="PamelloV7.Server.Consolonia.ConsoloniaApp"
             RequestedThemeVariant="Default">
             
    <Application.Styles>
        <console:ModernTheme />

        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="#323232" />
            <Setter Property="Foreground" Value="MediumPurple" />
        </Style>

        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Foreground" Value="MediumPurple" />
            <Setter Property="Background" Value="MediumPurple" />
        </Style>

        <Style Selector="ScrollBar /template/ RepeatButton">
            <Setter Property="Background" Value="#484856" />
        </Style>
    </Application.Styles>
</Application>