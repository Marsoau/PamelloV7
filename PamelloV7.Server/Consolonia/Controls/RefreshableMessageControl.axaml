<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:messages="clr-namespace:PamelloV7.Framework.Logging.Messages;assembly=PamelloV7.Framework"
             x:Class="PamelloV7.Server.Consolonia.Controls.RefreshableMessageControl"
>
    <Grid Name="Grid" ColumnDefinitions="Auto,*" x:DataType="messages:RefreshableLogMessage">
    </Grid>
</UserControl>