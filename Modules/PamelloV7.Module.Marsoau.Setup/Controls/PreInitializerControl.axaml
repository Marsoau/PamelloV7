<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PamelloV7.Module.Marsoau.Setup"
             x:Class="PamelloV7.Module.Marsoau.Setup.Controls.PreInitializerControl">
    <Grid Name="Grid" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="1">
        <TextBlock Grid.Column="0" Text="{Binding Path}"/>
        <TextBlock Grid.Column="1" Text="{Binding Type}" Foreground="YellowGreen"/>
    </Grid>
</UserControl>